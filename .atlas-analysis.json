  "keyFeatures": [
    "Role-based user authentication and authorization",
    "Service order and record management system",
    "Photo and document upload with file storage",
    "Mobile API with JWT authentication",
    "Excel import/export for bulk operations",
    "Financial reporting and analytics",
    "User assignment and management dashboard",
    "Real-time data synchronization with MongoDB"
  ],
  "publicApiSurface": [
    "POST /login - Authenticate users and obtain JWT token",
    "POST /refresh-token - Refresh expired JWT tokens",
    "POST /management - Create or update service records",
    "POST /management/photos/:orden - Upload photos for a service order",
    "GET /management/:username - Retrieve records for a specific user",
    "GET /health - Health check endpoint",
    "recordsCollection - MongoDB collection for service records",
    "photosCollection - MongoDB collection for photo storage",
    "documentsCollection - MongoDB collection for document storage",
    "Accounts.createUser() - Create new user accounts",
    "Meteor.userId() - Get current authenticated user ID",
    "useRole() - React hook for role-based access control"
  ]
}
